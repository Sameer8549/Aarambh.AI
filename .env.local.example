# Firebase Configuration
# Copy this file to .env.local and update with your actual Firebase project values
# Never commit .env.local to version control - it contains sensitive API keys

# Firebase Project Configuration
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# Google Cloud Project Configuration (for search service)
GCLOUD_PROJECT_ID=your-project-id
GCLOUD_DATA_STORE_ID=your-data-store-id

# Security Notes:
# 1. API keys should be rotated regularly (every 90 days recommended)
# 2. Use Firebase Security Rules to restrict access to your data
# 3. Monitor Firebase usage and set up billing alerts
# 4. Never commit actual keys to version control
# 5. Use different projects for development, staging, and production